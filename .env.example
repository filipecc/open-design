# AUTH1 front-door auth — copy to .env.local and fill in.
# .env.local is gitignored. NEVER commit real values; the repo stays vendor-neutral.

# Public hostname that fronts the deployment (OAuth redirect URI + daemon origin trust)
PUBLIC_HOST=your-app.example.com

# Google Workspace domain allowed to sign in (oauth2-proxy --email-domain)
OAUTH2_PROXY_EMAIL_DOMAINS=your-workspace-domain.com

# Google OAuth client — Google Cloud → APIs & Services → Credentials → OAuth client ID (Web application)
# Authorized redirect URI must be:  https://<PUBLIC_HOST>/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
OAUTH2_PROXY_CLIENT_SECRET=          # from Google Cloud — keep secret

# Session cookie secret (16/24/32 bytes):  openssl rand -base64 24
OAUTH2_PROXY_COOKIE_SECRET=

# Optional override (defaults to the internal web sidecar)
# OAUTH2_PROXY_UPSTREAM=http://127.0.0.1:3001
